{
  "name": "theme-customizer",
  "displayName": "Theme Customizer",
  "description": "Visually customize your VS Code theme colors, syntax highlighting, and editor settings",
  "version": "0.0.1",
  "engines": { "vscode": "^1.85.0" },
  "categories": ["Themes", "Other"],
  "activationEvents": [],
  "main": "./out/extension",
  "contributes": {
    "commands": [
      {
        "command": "themeCustomizer.open",
        "title": "Open Theme Customizer",
        "category": "Theme"
      },
      {
        "command": "themeCustomizer.clearState",
        "title": "Clear Stored State",
        "category": "Theme"
      }
    ],
    "keybindings": [
      {
        "command": "themeCustomizer.open",
        "key": "ctrl+shift+t",
        "mac": "cmd+shift+t",
        "when": "!terminalFocus"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  }
}
